CXX = g++
CXXFLAGS = -std=c++20 -Wall -Wextra -O2 -I.
LDFLAGS =

# Understanding Layer objects
UNDERSTANDING_OBJS = \
    understanding/mini_llm.o \
    understanding/understanding_layer.o

# Cognitive Dynamics objects (dependency)
COGNITIVE_OBJS = \
    cognitive/cognitive_dynamics.o

# Memory objects (dependency)
MEMORY_OBJS = \
    memory/stm.o \
    memory/brain_controller.o

# LTM objects (dependency)
LTM_OBJS = \
    ltm/long_term_memory.o

# Targets
all: test_understanding_layer demo_understanding_layer

test_understanding_layer: test_understanding_layer.o $(UNDERSTANDING_OBJS) $(COGNITIVE_OBJS) $(MEMORY_OBJS) $(LTM_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDFLAGS)

demo_understanding_layer: demo_understanding_layer.o $(UNDERSTANDING_OBJS) $(COGNITIVE_OBJS) $(MEMORY_OBJS) $(LTM_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDFLAGS)

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f understanding/*.o test_understanding_layer demo_understanding_layer *.o cognitive/*.o memory/*.o ltm/*.o

.PHONY: all clean

# Brain19 - Interactive Chat with Ollama LLM
CXX = g++
CXXFLAGS = -std=c++20 -Wall -Wextra -Wpedantic -O2 -I.
LDFLAGS = -lcurl

# Check if nlohmann-json is installed
JSON_HEADER := $(shell find /usr/include -name json.hpp 2>/dev/null | head -1)

SOURCES = \
	memory/stm.cpp \
	memory/brain_controller.cpp \
	ltm/long_term_memory.cpp \
	llm/ollama_client.cpp \
	llm/chat_interface.cpp

DEMO = demo_chat.cpp
OBJECTS = $(SOURCES:.cpp=.o)
DEMO_OBJ = demo_chat.o
TARGET = demo_chat

.PHONY: all clean run check-deps install-deps

all: check-deps $(TARGET)

check-deps:
	@echo "Checking dependencies..."
	@which curl >/dev/null 2>&1 || (echo "Error: curl not found. Install: apt install curl" && exit 1)
	@pkg-config --exists libcurl || (echo "Error: libcurl-dev not found. Install: apt install libcurl4-openssl-dev" && exit 1)
ifndef JSON_HEADER
	@echo "Error: nlohmann-json not found."
	@echo "Install: apt install nlohmann-json3-dev"
	@echo "Or run: make install-deps"
	@exit 1
endif
	@echo "✓ All dependencies OK"

install-deps:
	@echo "Installing dependencies..."
	@echo "You may need sudo privileges."
	apt update
	apt install -y libcurl4-openssl-dev nlohmann-json3-dev

$(TARGET): $(OBJECTS) $(DEMO_OBJ)
	@echo "Linking chat demo with Ollama..."
	$(CXX) $(CXXFLAGS) $(OBJECTS) $(DEMO_OBJ) -o $(TARGET) $(LDFLAGS)
	@echo "✓ Build complete: $(TARGET)"
	@echo ""
	@echo "Before running, make sure Ollama is installed and running:"
	@echo "  1. Install Ollama: curl -fsSL https://ollama.com/install.sh | sh"
	@echo "  2. Start Ollama: ollama serve"
	@echo "  3. Pull a model: ollama pull llama3.2:3b"
	@echo ""
	@echo "Then run: ./$(TARGET)"

%.o: %.cpp
	@echo "Compiling $<..."
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	@echo "Cleaning..."
	rm -f $(OBJECTS) $(DEMO_OBJ) $(TARGET)
	@echo "✓ Clean"

run: $(TARGET)
	@echo "Starting Brain19 Chat..."
	@echo ""
	@echo "Make sure Ollama is running: ollama serve"
	@echo ""
	./$(TARGET)
